{
  "expo": {
    "name": "SOMAP & SERVICE",
    "slug": "somap-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon_main.png",
    "scheme": "somap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
