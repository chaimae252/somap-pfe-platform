<svg width="390" height="844" viewBox="0 0 390 844" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgMain" x1="0" y1="0" x2="0.3" y2="1">
      <stop offset="0%" stop-color="#ffffff"/>
      <stop offset="50%" stop-color="#eaf3f8"/>
      <stop offset="100%" stop-color="#e6f0e8"/>
    </linearGradient>
  </defs>

  <!-- Base background -->
  <rect width="390" height="844" fill="url(#bgMain)"/>

  <!-- Grid lines -->
  <g opacity="0.04" stroke="#31507F" stroke-width="1">
    <line x1="0"   y1="0"   x2="0"   y2="844"/>
    <line x1="26"  y1="0"   x2="26"  y2="844"/>
    <line x1="52"  y1="0"   x2="52"  y2="844"/>
    <line x1="78"  y1="0"   x2="78"  y2="844"/>
    <line x1="104" y1="0"   x2="104" y2="844"/>
    <line x1="130" y1="0"   x2="130" y2="844"/>
    <line x1="156" y1="0"   x2="156" y2="844"/>
    <line x1="182" y1="0"   x2="182" y2="844"/>
    <line x1="208" y1="0"   x2="208" y2="844"/>
    <line x1="234" y1="0"   x2="234" y2="844"/>
    <line x1="260" y1="0"   x2="260" y2="844"/>
    <line x1="286" y1="0"   x2="286" y2="844"/>
    <line x1="312" y1="0"   x2="312" y2="844"/>
    <line x1="338" y1="0"   x2="338" y2="844"/>
    <line x1="364" y1="0"   x2="364" y2="844"/>
    <line x1="390" y1="0"   x2="390" y2="844"/>
    <line x1="0" y1="26"  x2="390" y2="26"/>
    <line x1="0" y1="52"  x2="390" y2="52"/>
    <line x1="0" y1="78"  x2="390" y2="78"/>
    <line x1="0" y1="104" x2="390" y2="104"/>
    <line x1="0" y1="130" x2="390" y2="130"/>
    <line x1="0" y1="156" x2="390" y2="156"/>
    <line x1="0" y1="182" x2="390" y2="182"/>
    <line x1="0" y1="208" x2="390" y2="208"/>
    <line x1="0" y1="234" x2="390" y2="234"/>
    <line x1="0" y1="260" x2="390" y2="260"/>
    <line x1="0" y1="286" x2="390" y2="286"/>
    <line x1="0" y1="312" x2="390" y2="312"/>
    <line x1="0" y1="338" x2="390" y2="338"/>
    <line x1="0" y1="364" x2="390" y2="364"/>
    <line x1="0" y1="390" x2="390" y2="390"/>
    <line x1="0" y1="416" x2="390" y2="416"/>
    <line x1="0" y1="442" x2="390" y2="442"/>
    <line x1="0" y1="468" x2="390" y2="468"/>
    <line x1="0" y1="494" x2="390" y2="494"/>
    <line x1="0" y1="520" x2="390" y2="520"/>
    <line x1="0" y1="546" x2="390" y2="546"/>
    <line x1="0" y1="572" x2="390" y2="572"/>
    <line x1="0" y1="598" x2="390" y2="598"/>
    <line x1="0" y1="624" x2="390" y2="624"/>
    <line x1="0" y1="650" x2="390" y2="650"/>
    <line x1="0" y1="676" x2="390" y2="676"/>
    <line x1="0" y1="702" x2="390" y2="702"/>
    <line x1="0" y1="728" x2="390" y2="728"/>
    <line x1="0" y1="754" x2="390" y2="754"/>
    <line x1="0" y1="780" x2="390" y2="780"/>
    <line x1="0" y1="806" x2="390" y2="806"/>
    <line x1="0" y1="832" x2="390" y2="832"/>
  </g>

  <!-- Decorative circles top-left -->
  <circle cx="-20" cy="60" r="130" fill="none" stroke="rgba(143,189,105,0.15)" stroke-width="1.5"/>
  <circle cx="-20" cy="60" r="80"  fill="none" stroke="rgba(19,172,213,0.1)"   stroke-width="1"/>

  <!-- Decorative circles bottom-right -->
  <circle cx="420" cy="780" r="160" fill="none" stroke="rgba(49,80,127,0.1)"  stroke-width="1.5"/>
  <circle cx="420" cy="780" r="100" fill="none" stroke="rgba(143,189,105,0.1)" stroke-width="1"/>

  <!-- Diamond shape mid-left -->
  <rect x="-30" y="380" width="80" height="80"
        fill="none" stroke="rgba(49,80,127,0.1)" stroke-width="1"
        transform="rotate(45 10 420)"/>

  <!-- Diamond shape mid-right -->
  <rect x="340" y="300" width="60" height="60"
        fill="none" stroke="rgba(19,172,213,0.1)" stroke-width="1"
        transform="rotate(45 370 330)"/>

  <!-- Brand stripe at 55% height -->
  <rect x="0" y="462" width="390" height="3"
        fill="url(#brandStripe)" opacity="0.6"/>
  <defs>
    <linearGradient id="brandStripe" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0%"   stop-color="transparent"/>
      <stop offset="15%"  stop-color="#31507F"/>
      <stop offset="40%"  stop-color="#13ACD5"/>
      <stop offset="65%"  stop-color="#8FBD69"/>
      <stop offset="100%" stop-color="transparent"/>
    </linearGradient>
  </defs>
  <rect x="0" y="465" width="390" height="1"
        fill="url(#brandStripe)" opacity="0.25"/>

  <!-- Dots / particles -->
  <circle cx="46"  cy="140" r="3" fill="rgba(143,189,105,0.5)"/>
  <circle cx="344" cy="200" r="2.5" fill="rgba(19,172,213,0.45)"/>
  <circle cx="30"  cy="560" r="3.5" fill="rgba(49,80,127,0.2)"/>
  <circle cx="360" cy="680" r="3" fill="rgba(143,189,105,0.35)"/>
  <circle cx="380" cy="420" r="2" fill="rgba(19,172,213,0.4)"/>
  <circle cx="195" cy="800" r="2.5" fill="rgba(49,80,127,0.2)"/>

  <!-- Big ghost S watermark -->
  <text x="-30" y="620" font-family="Arial Black, sans-serif" font-size="600"
        font-weight="900" fill="#8FBD69" opacity="0.04">S</text>
</svg>
